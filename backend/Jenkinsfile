pipeline {
    agent any

    environment {
        PROJECT_NAME = "flask-backend"
        APP_PATH = "/var/lib/jenkins/workspace/flask-backend-pipeline"
    }

    stages {
        stage('Checkout') {
            steps {
                // Checkout code from Git (Jenkins will handle this through job config)
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                sh '''
                    python3 -m venv venv
                    ./venv/bin/pip install -r requirements.txt
                '''
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                    # Check if pm2 process is running, reload if yes, start if no
                    pm2 describe $PROJECT_NAME > /dev/null
                    if [ $? -eq 0 ]; then
                        echo "Reloading existing application..."
                        pm2 restart $PROJECT_NAME
                    else
                        echo "Starting application for the first time..."
                        pm2 start app.py --name $PROJECT_NAME --interpreter=./venv/bin/python3 -- --port 5000
                    fi
                '''
            }
        }
    }

    post {
        success {
            echo "Flask Backend Deployed Successfully!"
        }
        failure {
            echo "Deployment Failed. Check logs."
        }
    }
}
